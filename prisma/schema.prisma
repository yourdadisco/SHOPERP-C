generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Shop {
  id                  String    @id @default(cuid())
  name                String
  shopifyDomain       String    @unique
  region              String    // 区域：北美/欧盟/英国/亚太
  currency            String    // 货币代码
  taxMode             String    // 含税/不含税
  apiKey              String?   // Shopify API密钥
  apiSecret           String?   // Shopify API密钥
  accessToken         String?   // Shopify访问令牌
  authorized          Boolean   @default(false)
  syncEnabled         Boolean   @default(true)
  lastSyncedAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  products            Product[]
  orders              Order[]
  inventories         Inventory[]
  purchases           Purchase[]
  finances            FinanceProfit[]
}

model Product {
  id                  String    @id @default(cuid())
  shopId              String
  shopifyProductId    String?
  title               String
  description         String?
  mainImage           String?
  status              String    // 上架/下架
  price               Float     // 默认价格
  costPrice           Float?    // 成本价
  weight              Float?    // 重量
  alertStock          Int?      // 预警库存
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shop                Shop      @relation(fields: [shopId], references: [id])
  skus                Sku[]
  orderItems          OrderItem[]
  inventories         Inventory[]
  purchases           PurchaseItem[]
}

model Sku {
  id                  String    @id @default(cuid())
  productId           String
  skuCode             String    @unique
  variantName         String?   // 变体名称
  price               Float?
  costPrice           Float?
  weight              Float?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  product             Product   @relation(fields: [productId], references: [id])
  inventories         Inventory[]
  orderItems          OrderItem[]
  purchaseItems       PurchaseItem[]
}

model Order {
  id                  String    @id @default(cuid())
  shopId              String
  orderNumber         String    @unique
  customerName        String?
  customerEmail       String?
  country             String
  region              String?
  currency            String
  paymentStatus       String    // 支付状态
  totalAmount         Float     // 实付金额
  shippingAmount      Float?
  taxAmount           Float?
  status              String    // 待审核/待发货/已完成/异常
  shippingStatus      String?   // 发货状态
  trackingNumber      String?
  warehouseId         String?
  warehouse           Warehouse? @relation(fields: [warehouseId], references: [id])
  internalNote        String?
  labels              Json      // 订单标签
  orderedAt           DateTime
  shippedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shop                Shop      @relation(fields: [shopId], references: [id])
  items               OrderItem[]
  logistics           Logistics?
  refunds             Refund[]
  finance             FinanceProfit?
}

model OrderItem {
  id                  String    @id @default(cuid())
  orderId             String
  productId           String
  skuId               String?
  quantity            Int
  price               Float
  totalAmount         Float
  createdAt           DateTime  @default(now())

  order               Order     @relation(fields: [orderId], references: [id])
  product             Product   @relation(fields: [productId], references: [id])
  sku                 Sku?      @relation(fields: [skuId], references: [id])
}

model Warehouse {
  id                  String    @id @default(cuid())
  name                String
  location            String?
  capacity            Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  inventories         Inventory[]
  orders              Order[]
  purchases           Purchase[]
}

model Inventory {
  id                  String    @id @default(cuid())
  shopId              String
  productId           String
  skuId               String?
  warehouseId         String
  availableStock      Int       @default(0)
  reservedStock       Int       @default(0)
  inTransitStock      Int       @default(0)
  location            String?   // 库位
  batch               String?   // 批次
  age                 Int?      // 库龄
  alertThreshold      Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shop                Shop      @relation(fields: [shopId], references: [id])
  product             Product   @relation(fields: [productId], references: [id])
  sku                 Sku?      @relation(fields: [skuId], references: [id])
  warehouse           Warehouse @relation(fields: [warehouseId], references: [id])
}

model Purchase {
  id                  String    @id @default(cuid())
  shopId              String
  supplier            String
  status              String    // 待审批/已批准/已发货/已入库
  totalAmount         Float
  expectedArrival     DateTime?
  shippingMethod      String?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shop                Shop      @relation(fields: [shopId], references: [id])
  warehouse           Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId         String
  items               PurchaseItem[]
}

model PurchaseItem {
  id                  String    @id @default(cuid())
  purchaseId          String
  productId           String
  skuId               String?
  quantity            Int
  unitPrice           Float
  totalPrice          Float
  createdAt           DateTime  @default(now())

  purchase            Purchase  @relation(fields: [purchaseId], references: [id])
  product             Product   @relation(fields: [productId], references: [id])
  sku                 Sku?      @relation(fields: [skuId], references: [id])
}

model Logistics {
  id                  String    @id @default(cuid())
  orderId             String    @unique
  carrier             String    // 物流商
  channel             String    // 物流渠道
  estimatedDays       Int?
  trackingNumber      String
  shippingLabelUrl    String?
  status              String    // 已发货/运输中/已送达
  shippedAt           DateTime
  deliveredAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  order               Order     @relation(fields: [orderId], references: [id])
}

model Refund {
  id                  String    @id @default(cuid())
  orderId             String
  type                String    // 退款/退货
  reason              String?
  amount              Float
  status              String    // 处理中/已完成
  returnAddress       String?
  processedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  order               Order     @relation(fields: [orderId], references: [id])
}

model FinanceProfit {
  id                  String    @id @default(cuid())
  shopId              String
  orderId             String @unique
  date                DateTime
  salesAmount         Float     // 销售额
  productCost         Float     // 商品成本
  shippingCost        Float     // 物流费
  platformFee         Float     // 平台费
  transactionFee      Float     // 交易费
  taxAmount           Float     // 税费
  netProfit           Float     // 净利润
  margin              Float     // 毛利率
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shop                Shop      @relation(fields: [shopId], references: [id])
  order               Order?    @relation(fields: [orderId], references: [id])
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  passwordHash        String
  role                String    // 超级管理员/运营/仓储/采购/财务/客服
  permissions         Json      // 权限列表
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model SystemLog {
  id                  String    @id @default(cuid())
  userId              String?
  action              String
  resource            String?
  details             Json?
  ipAddress           String?
  userAgent           String?
  createdAt           DateTime  @default(now())
}